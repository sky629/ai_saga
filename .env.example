# ============================================================================
# AI Saga 환경 변수 예시
# 로컬 개발과 AWS EC2 외부 테스트 배포를 모두 커버하는 단일 예시 파일
# 이 파일을 복사해서 .env 로 사용하세요.
# 예: cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# 배포 메타
# ----------------------------------------------------------------------------
# 외부 테스트용 EC2 직접 빌드에서는 기본값 그대로 둬도 됩니다.
# ECR 방식을 다시 쓰고 싶을 때만 원격 이미지 URI로 바꾸세요.
APP_IMAGE=ai-saga:ec2

# 외부 테스트 배포 시 CloudFront가 연결할 API 도메인입니다.
APP_DOMAIN=api.example.com

# local / beta / prod
# prod이면 개발용 라우트가 비활성화됩니다.
KANG_ENV=local

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
# 로컬 개발: POSTGRES_HOST=localhost
# EC2 docker compose: POSTGRES_HOST=postgres
POSTGRES_DB=ai_saga
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 테스트 DB도 앱 설정상 필요합니다.
# 로컬 개발: TEST_POSTGRES_HOST=localhost
# EC2 docker compose: TEST_POSTGRES_HOST=postgres
TEST_POSTGRES_DB=ai_saga_test
TEST_POSTGRES_USER=postgres
TEST_POSTGRES_PASSWORD=your_secure_password_here
TEST_POSTGRES_HOST=localhost
TEST_POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
# 로컬 개발: redis://localhost:6379
# EC2 docker compose: redis://redis:6379
REDIS_URL=redis://localhost:6379
REDIS_AUTH_DB=1

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
# openssl rand -hex 32 로 생성 권장
JWT_SECRET_KEY=your_super_secret_jwt_key_here_generate_with_openssl
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=1440
JWT_SESSION_EXPIRE_MINUTES=1440

# ----------------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------------
# 로컬 개발 예시:
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/
# 외부 테스트 배포 예시:
# GOOGLE_REDIRECT_URI=https://api.example.com/api/v1/auth/google/callback/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/

# ----------------------------------------------------------------------------
# Gemini
# ----------------------------------------------------------------------------
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# 게임 설정
# ----------------------------------------------------------------------------
GAME_MIN_TURNS=1
GAME_MAX_TURNS=30
RAG_RECENT_MESSAGES_LIMIT=10
RAG_SIMILAR_MESSAGES_LIMIT=2
RAG_DISTANCE_THRESHOLD=0.3
RAG_SIMILARITY_WEIGHT=0.7
RAG_RECENCY_WEIGHT=0.3

# ----------------------------------------------------------------------------
# Kafka
# ----------------------------------------------------------------------------
# 현재 핵심 플레이 플로우에는 필수는 아니지만 기존 설정 구조를 유지합니다.
# 로컬 개발: localhost:9092
# EC2 외부 테스트: kafka:9092 또는 미사용 시 그대로 둬도 무방
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ----------------------------------------------------------------------------
# 프론트엔드 / CORS
# ----------------------------------------------------------------------------
# 로컬 개발 예시:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
# FRONTEND_LOGIN_SUCCESS_URL=http://localhost:5173/auth/login/success
#
# 외부 테스트 배포 예시:
# ALLOWED_ORIGINS=https://www.example.com,https://example.com
# FRONTEND_LOGIN_SUCCESS_URL=https://www.example.com/auth/login/success
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
FRONTEND_LOGIN_SUCCESS_URL=http://localhost:5173/auth/login/success

# ----------------------------------------------------------------------------
# 이미지 생성
# ----------------------------------------------------------------------------
# 실제로 이미지 생성 기능을 쓰지 않으면 false 유지
IMAGE_GENERATION_ENABLED=false
IMAGE_MODEL=imagen-3.0-generate-001

# Cloudflare R2
# 이미지 생성 기능을 켜는 경우에만 필요
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=ai-saga
R2_PUBLIC_URL=

# ----------------------------------------------------------------------------
# Sentry
# ----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENABLED=true
SENTRY_ENABLED_ENVIRONMENTS=beta,prod
SENTRY_TRACES_SAMPLE_RATE=0.05
# Optional override: true/false (if omitted, local/beta=true, prod=false)
# SENTRY_ENABLE_LOGS=false
SENTRY_SEND_DEFAULT_PII=false
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.0
SENTRY_PROFILE_LIFECYCLE=trace
